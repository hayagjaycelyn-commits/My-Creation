<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kumon Tanza (Cavite) Center — Class Schedule</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=DM+Serif+Display&display=swap" rel="stylesheet">
<style>
  :root {
    --blue: #1565C0;
    --blue-light: #E3F2FD;
    --blue-dark: #0D47A1;
    --red: #B71C1C;
    --red-light: #FFEBEE;
    --red-dark: #7F0000;
    --gray: #F5F5F5;
    --border: #E0E0E0;
    --text: #1A1A1A;
    --muted: #757575;
    --white: #ffffff;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: "DM Sans", sans-serif; background: #FAFAFA; color: var(--text); min-height: 100vh; }

  .hero {
    background: var(--blue-dark);
    padding: 2.5rem 2rem 2rem;
    text-align: center;
  }
  .hero-label { font-size: 11px; font-weight: 600; letter-spacing: 2px; color: #90CAF9; text-transform: uppercase; margin-bottom: 8px; }
  .hero-title { font-family: "DM Serif Display", serif; font-size: 28px; color: white; line-height: 1.2; margin-bottom: 6px; }
  .hero-sub { font-size: 14px; color: #90CAF9; }

  .search-wrap { max-width: 680px; margin: 1.5rem auto 0; padding: 0 1rem; }
  .search-wrap input {
    width: 100%; padding: 12px 16px; font-size: 15px; font-family: "DM Sans", sans-serif;
    border: none; border-radius: 10px; outline: none;
    background: white; color: var(--text);
    box-shadow: 0 2px 8px rgba(0,0,0,0.12);
  }

  .tabs { display: flex; gap: 8px; justify-content: center; padding: 1.25rem 1rem 0; flex-wrap: wrap; }
  .tab {
    padding: 7px 18px; border-radius: 20px; font-size: 13px; font-weight: 500;
    cursor: pointer; border: 1.5px solid var(--border);
    background: white; color: var(--muted); transition: all 0.15s;
  }
  .tab:hover { border-color: #BDBDBD; color: var(--text); }
  .tab.active-all { background: var(--text); color: white; border-color: var(--text); }
  .tab.active-blue { background: var(--blue); color: var(--blue-light); border-color: var(--blue); }
  .tab.active-red { background: var(--red); color: var(--red-light); border-color: var(--red); }

  .legend { display: flex; gap: 20px; justify-content: center; padding: 1rem; flex-wrap: wrap; }
  .leg { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--muted); }
  .leg-dot { width: 10px; height: 10px; border-radius: 2px; }

  .container { max-width: 680px; margin: 0 auto; padding: 0.5rem 1rem 3rem; }
  .results { display: flex; flex-direction: column; gap: 10px; }

  .card {
    background: white; border: 1px solid var(--border); border-radius: 12px;
    padding: 1rem 1.25rem; transition: box-shadow 0.15s;
  }
  .card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
  .card-top { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
  .avatar {
    width: 42px; height: 42px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 600; flex-shrink: 0;
  }
  .av-blue { background: var(--blue-light); color: var(--blue-dark); }
  .av-red { background: var(--red-light); color: var(--red-dark); }
  .student-name { font-size: 15px; font-weight: 600; color: var(--text); }
  .student-level { font-size: 12px; color: var(--muted); margin-top: 2px; }
  .day-badge {
    margin-left: auto; font-size: 11px; font-weight: 600;
    padding: 3px 10px; border-radius: 4px;
  }
  .db-blue { background: var(--blue); color: var(--blue-light); }
  .db-red { background: var(--red); color: var(--red-light); }
  .db-both { background: #4A148C; color: #EDE7F6; }

  .schedule-row { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px; }
  .pill {
    padding: 5px 12px; border-radius: 20px; font-size: 12px; font-weight: 500;
  }
  .pill-blue { background: var(--blue-light); color: var(--blue-dark); }
  .pill-red { background: var(--red-light); color: var(--red-dark); }

  .gcal-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 7px 14px; border-radius: 8px; font-size: 12px; font-weight: 500;
    cursor: pointer; text-decoration: none; border: 1.5px solid var(--border);
    background: white; color: var(--muted); transition: all 0.15s; margin-right: 6px; margin-top: 4px;
  }
  .gcal-btn:hover { border-color: #4285F4; color: #4285F4; background: #F8F9FF; }
  .gcal-icon { width: 14px; height: 14px; }

  .empty { text-align: center; padding: 3rem 1rem; color: var(--muted); font-size: 14px; }
  .count-label { font-size: 12px; color: var(--muted); margin-bottom: 10px; }
</style>
</head>
<body>

<div class="hero">
  <div class="hero-label">Class Schedule</div>
  <div class="hero-title">Kumon Tanza (Cavite) Center</div>
  <div class="hero-sub">May 2026 — Regular Weekly Sessions</div>
  <div class="search-wrap">
    <input type="text" id="searchInput" placeholder="Search your name..." oninput="render()" />
  </div>
</div>

<div class="tabs">
  <div class="tab active-all" onclick="setFilter('all',this)">All students</div>
  <div class="tab" onclick="setFilter('blue',this)">Mon & Thu</div>
  <div class="tab" onclick="setFilter('red',this)">Tue & Fri</div>
</div>

<div class="legend">
  <div class="leg"><div class="leg-dot" style="background:var(--blue)"></div>Monday & Thursday</div>
  <div class="leg"><div class="leg-dot" style="background:var(--red)"></div>Tuesday & Friday</div>
  <div class="leg"><div class="leg-dot" style="background:#CFD8DC"></div>Wednesday — Day Off</div>
</div>

<div class="container">
  <div class="count-label" id="countLabel"></div>
  <div class="results" id="results"></div>
</div>

<script>
const CENTER = "Kumon Tanza (Cavite) Center";

const students = [
  {name:"Mohammad", level:"Level B", group:"blue", time:"9:00 AM", hour:9},
  {name:"Lauriz", level:"Level B", group:"blue", time:"9:00 AM", hour:9},
  {name:"Eumar", level:"Level A", group:"both", time:"9:00 AM", hour:9},
  {name:"Dwight", level:"Level 2A", group:"blue", time:"10:00 AM", hour:10},
  {name:"Frances", level:"Level B", group:"blue", time:"10:00 AM", hour:10},
  {name:"Justino", level:"Level B", group:"blue", time:"10:00 AM", hour:10},
  {name:"Alexandra", level:"Level B", group:"red", time:"10:00 AM", hour:10},
  {name:"Zeia", level:"Level B", group:"red", time:"10:00 AM", hour:10},
  {name:"Dwayne", level:"Level 4A", group:"red", time:"10:00 AM", hour:10},
  {name:"Vania", level:"Level B", group:"blue", time:"11:00 AM", hour:11},
  {name:"Armida", level:"Level B", group:"blue", time:"11:00 AM", hour:11},
  {name:"Manzo", level:"Level 3A", group:"blue", time:"11:00 AM", hour:11},
  {name:"Clancy", level:"Level A", group:"red", time:"11:00 AM", hour:11},
  {name:"Zia", level:"Level B", group:"red", time:"1:00 PM", hour:13},
  {name:"Kian", level:"Level 4A", group:"red", time:"1:00 PM", hour:13},
  {name:"Rebekah", level:"Level C", group:"red", time:"1:00 PM", hour:13},
  {name:"Augustin", level:"Level C", group:"red", time:"2:00 PM", hour:14},
  {name:"Julian", level:"Level 2A", group:"red", time:"2:00 PM", hour:14},
  {name:"Merielle", level:"Level 2A", group:"red", time:"2:00 PM", hour:14},
  {name:"Ezra", level:"Level 4A", group:"red", time:"3:00 PM", hour:15},
  {name:"Alika", level:"Level 2A", group:"red", time:"3:00 PM", hour:15},
  {name:"Yoona", level:"Level B", group:"red", time:"3:00 PM", hour:15},
  {name:"Giselle", level:"Level A", group:"blue", time:"4:00 PM", hour:16},
  {name:"Arcess", level:"Level B", group:"blue", time:"4:00 PM", hour:16},
  {name:"Akio", level:"Level B", group:"blue", time:"4:00 PM", hour:16},
  {name:"Xion Carl", level:"Level 2A", group:"red", time:"4:00 PM", hour:16},
  {name:"Cedrick", level:"Level 2A", group:"red", time:"4:00 PM", hour:16},
  {name:"Gabrhen", level:"Level B", group:"red", time:"4:00 PM", hour:16},
  {name:"Sabina", level:"Level 2A", group:"blue", time:"5:00 PM", hour:17},
  {name:"Jomara", level:"Level 2A", group:"blue", time:"5:00 PM", hour:17},
  {name:"Matthew", level:"Level B", group:"blue", time:"5:00 PM", hour:17},
  {name:"Avrae", level:"Level A", group:"red", time:"5:00 PM", hour:17},
  {name:"Aurelia", level:"Level A", group:"red", time:"5:00 PM", hour:17},
  {name:"Don Bernard", level:"Level B", group:"red", time:"5:00 PM", hour:17},
];

let currentFilter = "all";

function initials(name) {
  return name.split(" ").map(w=>w[0]).join("").toUpperCase().slice(0,2);
}

function gcalDate(dayOffset, hour) {
  const base = new Date("2026-05-04");
  base.setDate(base.getDate() + dayOffset);
  const y = base.getFullYear();
  const m = String(base.getMonth()+1).padStart(2,"0");
  const d = String(base.getDate()).padStart(2,"0");
  const hStart = String(hour).padStart(2,"0");
  const hEnd = String(hour+1).padStart(2,"0");
  return {
    start: y+m+d+"T"+hStart+"0000",
    end:   y+m+d+"T"+hEnd+"0000"
  };
}

function gcalUrl(s, dayOffset, label) {
  const dt = gcalDate(dayOffset, s.hour);
  const title = encodeURIComponent(CENTER+" — "+s.name+" ("+s.level+")");
  const details = encodeURIComponent("Kumon class for "+s.name+". Level: "+s.level);
  const loc = encodeURIComponent("Kumon Tanza Cavite Center");
  return "https://calendar.google.com/calendar/render?action=TEMPLATE"
    +"&text="+title
    +"&dates="+dt.start+"/"+dt.end
    +"&details="+details
    +"&location="+loc
    +"&recur=RRULE:FREQ=WEEKLY"
    +"&sf=true&output=xml";
}

function gcalIcon() {
  return `<svg class="gcal-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/>
    <path d="M3 9h18" stroke="currentColor" stroke-width="1.5"/>
    <path d="M8 2v4M16 2v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  </svg>`;
}

function renderCard(s) {
  const isBlue = s.group==="blue", isRed=s.group==="red", isBoth=s.group==="both";
  const avClass = isRed ? "av-red" : "av-blue";
  const badgeClass = isBoth ? "db-both" : isBlue ? "db-blue" : "db-red";
  const badgeText = isBoth ? "Mon/Thu + Tue/Fri" : isBlue ? "Mon & Thu" : "Tue & Fri";

  let pills = "";
  let btns = "";
  if (isBlue || isBoth) {
    pills += `<span class="pill pill-blue">Mon & Thu — ${s.time}</span>`;
    btns += `<a class="gcal-btn" href="${gcalUrl(s,1,"Mon")}" target="_blank">${gcalIcon()} Add Mon & Thu to Google Calendar</a>`;
  }
  if (isRed || isBoth) {
    pills += `<span class="pill pill-red">Tue & Fri — ${s.time}</span>`;
    btns += `<a class="gcal-btn" href="${gcalUrl(s,2,"Tue")}" target="_blank">${gcalIcon()} Add Tue & Fri to Google Calendar</a>`;
  }

  return `<div class="card">
    <div class="card-top">
      <div class="avatar ${avClass}">${initials(s.name)}</div>
      <div>
        <div class="student-name">${s.name}</div>
        <div class="student-level">${s.level}</div>
      </div>
      <span class="day-badge ${badgeClass}">${badgeText}</span>
    </div>
    <div class="schedule-row">${pills}</div>
    <div>${btns}</div>
  </div>`;
}

function setFilter(f, el) {
  currentFilter = f;
  document.querySelectorAll(".tab").forEach(t => t.className = "tab");
  if (f==="all") el.className = "tab active-all";
  else if (f==="blue") el.className = "tab active-blue";
  else el.className = "tab active-red";
  render();
}

function render() {
  const q = document.getElementById("searchInput").value.toLowerCase().trim();
  let filtered = students;
  if (currentFilter==="blue") filtered = filtered.filter(s=>s.group==="blue"||s.group==="both");
  if (currentFilter==="red") filtered = filtered.filter(s=>s.group==="red"||s.group==="both");
  if (q) filtered = filtered.filter(s=>s.name.toLowerCase().includes(q));
  const el = document.getElementById("results");
  const cl = document.getElementById("countLabel");
  cl.textContent = filtered.length + " student" + (filtered.length!==1?"s":"") + " found";
  el.innerHTML = filtered.length ? filtered.map(renderCard).join("") : "<div class='empty'>No student found. Try a different name.</div>";
}

render();
</script>
</body>
</html>
